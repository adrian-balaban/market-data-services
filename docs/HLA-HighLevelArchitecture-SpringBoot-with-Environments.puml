@startuml

skinparam linetype ortho #polyline
'top to bottom direction
left to right direction

actor "User (various roles)" as User #LightBlue

cloud {
  node "Github" {
    [Source Repositories]
  }
  package "Bloomberg B-PIPE Environments" {
      node "B-PIPE" #Orange {
      }
  }
}

package "Visa" as Visa #LightBlue {
    package "Currency Cloud" {
      package "Controller Environments" {
        package "Controller Environment for Dev & Test envs.under distinct AWS Subscription" as ControllerTEST #Yellow {
          [AWS Secrets for Dev & Test]
          [Jenkins for Dev & Test]
          [DataDog for Dev & Test]
        }
        package "Controller Environment for Preprod & Prod under distinct AWS Subscription" as ControllerPROD #Yellow {
          [Common Container and Maven Registries for all envs.]
          [AWS Secrets for  Preprod & Prod]
          [ArgoCD for  Preprod & Prod]
          [DataDog for  Preprod & Prod]
          [AWS S3 buckets for terraform states for all envs. ?]
        }
      }
      package "Work Environments" {
          node "Dev Clusters (distinct AWS Subscription ?)" as Dev #Orange {
          }
          node "Test Cluster (distinct AWS Subscription ?)" as Test #Green {
          }
          node "PreProd Cluster (distinct AWS Subscription ?)" as PreProd #Magenta {
          }
          node "Prod Cluster (distinct AWS Subscription ?) " as Prod #Aqua {
          }
      }
    }
    package "Kafka Environments" {
        node "Dev" as KafkaDev #Orange {
        }
        node "Test" as KafkaTest #Green {
        }
        node "PreProd" as KafkaPreProd #Magenta {
        }
        node "Prod" as KafkaProd #Aqua {
        }
    }

    package "Consumers of data" {
        node "Dev" as ConsumersDev #Orange {
        }
        node "Test" as ConsumersTest #Green {
        }
        node "PreProd" as ConsumersPreProd #Magenta {
        }
        node "Prod" as ConsumersProd #Aqua {
        }
    }
    package "Producers of data for CurrencyCloud" {
        node "Dev" as ProducersDev #Orange {
        }
        node "Test" as ProducersTest #Green {
        }
        node "PreProd" as ProducersPreProd #Magenta {
        }
        node "Prod" as ProducersProd #Aqua {
        }
    }
}

User --> ControllerTEST
User --> ControllerPROD

/'note top of Controller
  Controller is on the main AWS subscription
  and the 1-st to deploy with Terraform
end note'/
@enduml

